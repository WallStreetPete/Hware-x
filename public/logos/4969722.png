<script>
	$(document).ready(function () {
		$.ajax({type:'POST',url:'./include/code.session.left.ajax.inc.php?style=img',data:'',success:function(mydata){}});
		$("#dynaImg").attr({ src: "./include/code.createimgLeft.inc.php?rand="+Math.random() });

		$("#dynaImg").click(
			function(){
				$.ajax({type:'POST',url:'./include/code.session.left.ajax.inc.php?style=img',data:'',success:function(mydata){}});
				$("#dynaImg").attr({ src: "./include/code.createimgLeft.inc.php?rand="+Math.random() });

		});

		$("#contactSend").click(
			function(){
				if(!RadioCheck(contactForm.contactTypeName,"contactType")){
					return false;
				}

				if($("#contactTypeName").val()=="Sales" && ($("#contactTypeNameSel").val()=="" || $("#contactTypeNameSel").val()==null)){
					alert("Please Select Sales Type!");
					$("#contactTypeNameSel").focus();
					return false;
				}

				//必須輸入資料
				var mustEnterData=new Array(
									$("#firstName"),
									$("#lastName"),
									
									$("#contact_email"),
									$("#company"),
									$("#country"),
									$("#tel"),
									$("#message"),
									$("#leftCode")
									);
				//判斷必填資料欄位
				if(chkMustEnterData(mustEnterData)==false){
					return false;
				}

				//if(!RadioCheck(contactForm.sex,"Sex")){
				//	return false;
				//}

				//email
				if(trim($("#contact_email").val())==''){
					alert("請輸入聯絡信箱");
					$("#contact_email").focus();
					return false;
				}
				if(!chkEmailjQuery($("#contact_email"))){
					//alert('輸入的Email格式有誤!');
					$("#contact_email").focus();
					return false;
				}

				//$("#contactForm").submit();
				if(confirm('請再次確認，謝謝。')){
					$("#contactSend").hide();
					//AJAX
					$.ajax({
					  url: "ajax/ajax_add_contact2.php",
					  type: "POST",
					  dataType: "text",
					  data:$("#contactForm").serialize(),
					  success: function(mydata) {
						  if(mydata!="success"){
							  alert(mydata);
							  $("#contactSend").show();
						  }else{
							  //alert("請再次確認您的留言，謝謝。");
							  //連結計數頁
							  location.replace("contact-ok.php");

						  }
					  },
					  error: function() {
					    alert("AJAX ERROR!!!");
					    $("#contactSend").show();
					  }
					});
				}

		});
	});
</script>
