                                        <div class="flex gap-6 items-center h-[68px] py-3 px-4 md:py-0 md:px-0">
                                            <div class="w-[182px] h-[32px] flex-shrink-0 flex items-center justify-start">
                                                <a href="/"><img class="w-full h-full object-contain object-left hidden md:block" src="/-/media/image/logo/kulickesoffa-fulllogo-colour.svg" alt="logo" loading="lazy" /></a>
                                            </div>
                                            <div class="flex-1 h-full flex items-center justify-end">
                                                <div class="flex w-auto md:w-30 justify-end">
                                                    <div class="md:bg-neutral-extralight rounded-lg md:p-2 cursor-pointer" x-on:click="toggle()">
                                                        <svg width="24" height="24" aria-hidden="true" focusable="false" class="rotate-45 text-neutral-semidark">
                                                            <use href="/assets/icons/outlined/sprite.svg#plus" xlink:href="/assets/icons/outlined/sprite.svg#plus" fill="currentColor"></use>
                                                        </svg>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="header-search-content w-full relative z-20 bg-neutral-ultralight">
                                    <div class="generic-container md:p-20 pt-16 px-5 pb-5">
                                        <div class="w-full md:w-[1000px] bg-neutral-ultralight md:mx-auto">
                                            <div class="rte text-center w-full mb-10"><h3 class="heading-3"><span class="text-neutral-extradark">Find what <span class="text-primary-mystic-red-standard">matters.</span></span></h3></div>
                                            <div class="">
                                                <div class="w-full mx-auto p-4">
                                                    <div class="relative">
                                                        <form x-on:submit="redirectToResults($event)">
                                                            <div class="absolute left-3 top-1/2 -translate-y-1/2 flex items-center pointer-events-none">
                                                                <img class="w-8 h-8 object-cover" src="/assets/icons/search-icon.svg" alt="globe" loading="lazy" />
                                                            </div>
                                                            <input type="text"
                                                                   x-model="searchValue"
                                                                   class="w-full pl-12 pr-12 py-4 h-14 text-neutral-extradark placeholder-neutral-semilight bg-white border border-neutral-light rounded-xl focus:outline-none focus:ring-1 focus:border-neutral-base"
                                                                   x-bind:placeholder="ghostText"
                                                                   x-on:input="submitSearch($event)" /><button type="button" x-show="searchValue.length &gt; 0" class="absolute top-1/2 -translate-y-1/2 right-4 flex items-center cursor-pointer">
                                                                <div class="bg-neutral-extralight rounded-xl p-1" x-on:click="clearSearch()">
                                                                    <svg width="12"
                                                                         height="12"
                                                                         aria-hidden="true"
                                                                         focusable="false"
                                                                         class="rotate-45 text-neutral-extradark">
                                                                        <use href="/assets/icons/outlined/sprite.svg#plus" xlink:href="/assets/icons/outlined/sprite.svg#plus" fill="currentColor"></use>
                                                                    </svg>
                                                                </div>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="h-[150px] w-full flex items-center justify-center" x-show="isDirty && results.length <= 0">
                                               
                                                    <p class="body-1 text-neutral-extradark" x-show="searchValue.length >= 1 && searchValue.length < charCount">Search requires at least 3 characters</p>

                                                <template x-if="searchValue.length >= charCount && results.length <= 0 && isSubmitted">
                                                    <div class="body-1-semibold text-neutral-extradark">
                                                        <p class="body-1-bold" style="text-align: left;"><span class="text-neutral-dark">No result found</span></p>
                                                    </div>
                                                </template>
                                            </div>
                                            <div class="quickLinks px-3 md:px-0" x-show="!isDirty">
                                                <p class="body-2-semibold text-neutral-base px-4 py-3">Quick links</p>
                                                <div class="grid md:grid-cols-2 grid-cols-1">
                                                        <a class="flex px-4 py-4 items-center hover:bg-neutral-extralight rounded-md" href="/products-services"
                                                           data-event="link_clicks"
                                                           data-click-label="products-services"
                                                           data-click-url="/products-services"
                                                           data-page-section="Header">
                                                            <svg width="16" height="16" aria-hidden="true" focusable="false" class="">
                                                                <use href="/assets/icons/outlined/sprite.svg#right-arrow" xlink:href="/assets/icons/outlined/sprite.svg#right-arrow" fill="currentColor"></use>
                                                            </svg>
                                                            <p class="body-2-regular text-neutral-extradark ml-4">Products &amp; Services</p>
                                                        </a>
                                                        <a class="flex px-4 py-4 items-center hover:bg-neutral-extralight rounded-md" href="/company"
                                                           data-event="link_clicks"
                                                           data-click-label="company"
                                                           data-click-url="/company"
                                                           data-page-section="Header">
                                                            <svg width="16" height="16" aria-hidden="true" focusable="false" class="">
                                                                <use href="/assets/icons/outlined/sprite.svg#right-arrow" xlink:href="/assets/icons/outlined/sprite.svg#right-arrow" fill="currentColor"></use>
                                                            </svg>
                                                            <p class="body-2-regular text-neutral-extradark ml-4">Company</p>
                                                        </a>
                                                        <a class="flex px-4 py-4 items-center hover:bg-neutral-extralight rounded-md" href="/careers"
                                                           data-event="link_clicks"
                                                           data-click-label="careers"
                                                           data-click-url="/careers"
                                                           data-page-section="Header">
                                                            <svg width="16" height="16" aria-hidden="true" focusable="false" class="">
                                                                <use href="/assets/icons/outlined/sprite.svg#right-arrow" xlink:href="/assets/icons/outlined/sprite.svg#right-arrow" fill="currentColor"></use>
                                                            </svg>
                                                            <p class="body-2-regular text-neutral-extradark ml-4">Careers</p>
                                                        </a>
                                                        <a class="flex px-4 py-4 items-center hover:bg-neutral-extralight rounded-md" href="/investors"
                                                           data-event="link_clicks"
                                                           data-click-label="investors"
                                                           data-click-url="/investors"
                                                           data-page-section="Header">
                                                            <svg width="16" height="16" aria-hidden="true" focusable="false" class="">
                                                                <use href="/assets/icons/outlined/sprite.svg#right-arrow" xlink:href="/assets/icons/outlined/sprite.svg#right-arrow" fill="currentColor"></use>
                                                            </svg>
                                                            <p class="body-2-regular text-neutral-extradark ml-4">Investors</p>
                                                        </a>
                                                </div>
                                            </div>
                                            <div class="searchSuggestions px-3 md:px-0" x-show="results.length > 0">
                                                <p class="body-2-semibold text-neutral-base px-4 py-3">Suggested searches</p>
                                                <div class="grid md:grid-cols-2 grid-cols-1">
                                                    <template x-for="result in results">
                                                        <a class="flex px-4 py-4 items-center hover:bg-neutral-extralight rounded-md" x-bind:href="encodeQueryParams(result.Url)"
                                                           data-event="link_clicks"
                                                           x-bind:data-click-label="result.Text"
                                                           x-bind:data-click-url="result.Url"
                                                           data-page-section="Header">
                                                            <img class="w-6 h-6 object-cover" src="/assets/icons/search-icon.svg" alt="globe" loading="lazy" />
                                                            <p class="body-2-regular text-neutral-extradark ml-4 highlight-match" x-ref="highlightMatch" x-text='result.Text'></p>
                                                        </a>
                                                    </template>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="left-0 absolute top-1/2 -translate-y-1/2 hidden md:block"><img src="/assets/images/header/left-pattern.svg" /></div>
                                    <div class="right-0 absolute top-1/2 -translate-y-1/2 hidden md:block"><img src="/assets/images/header/right-pattern.svg" /></div>
                                </div>
                                <div x-show="isOpen"
                                     x-on:click="toggle()"
                                     class="overlay-bg fixed top-[68px] left-0 w-screen h-screen bg-black/60 z-10 backdrop-blur-sm"
                                     x-transition:enter="transition-opacity ease-out duration-100"
                                     x-transition:enter-start="opacity-0"
                                     x-transition:enter-end="opacity-100"
                                     x-transition:leave="transition-opacity ease-in duration-100"
                                     x-transition:leave-start="opacity-100"
                                     x-transition:leave-end="opacity-0"></div>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </div>



