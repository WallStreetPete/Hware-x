<div x-cloak="true"
     class="cookies-policy  w-full flex flex-col gap-2 justify-center px-5 pt-5 pb-[18px] md:px-8 md:pt-8 md:pb-8 z-30"
     x-data="cookiesPolicy({})"
     x-show="showCookiesPolicy">
    <h6 class="heading-6">Cookie Settings</h6>
    <p class="body-2-regular line-clamp-3">We use cookies to provide you the best experience on our website. By accepting this message, you agree to our use of cookies.</p>
    <div class="mt-4 md:mt-6 flex gap-3 md:gap-6">
        <button type="button"
                class="uppercase md:!w-[130px] md:!min-w-[130px] !w-[120px] !min-w-[120px] group rounded-200 hover:not-disabled:rounded-300 transition-all duration-250 not-disabled:cursor-pointer inline-flex min-w-[200px] max-w-[318px] font-bold h-min border border-transparent hover:not-active:not-disabled:border-primary-mystic-red-light"
                x-on:click="saveAndClose()"
                data-event="button_clicks"
                data-click-label="ACCEPT"
                data-page-section="Cookies Policy">
            <div class="w-full bg-button-wrapper transition-all duration-250 rounded-200 relative z-5 overflow-hidden flex justify-center items-center py-3 px-4 text-sm">
                <div class="absolute w-full h-full transition-all duration-300 z-1 group-hover:group-not-active:group-not-disabled:p-1">
                    <div class="w-full h-full rounded-200 transition-all duration-400 bg-primary-mystic-red-standard group-hover:bg-primary-mystic-red-middle group-disabled:bg-neutral-light/30"></div>
                </div>
                <div class="inline-flex items-center gap-x-2 relative z-5 w-full md:w-auto justify-center min-w-0">
                    <span class="text-center  min-w-0 flex-1 text-neutral-ultralight group-disabled:text-neutral-light">ACCEPT</span>
                </div>
            </div>
        </button>
        <button type="button"
                class="uppercase md:!w-[130px] md:!min-w-[130px] !w-[120px] !min-w-[120px] group rounded-200 hover:not-disabled:rounded-300 transition-all duration-250 not-disabled:cursor-pointer inline-flex min-w-[200px] max-w-[318px] font-bold h-min border rounded-300 not-disabled:border-primary-mystic-red-standard hover:not-disabled:border-primary-mystic-red-light border-neutral-light/60"
                x-on:click="$dispatch(&#39;openDialog&#39;, { id: &#39;cookiesPolicy&#39; })"
                data-event="button_clicks"
                data-click-label="CUSTOMIZE"
                data-page-section="Cookies Policy">
            <div class="w-full bg-button-wrapper transition-all duration-250 rounded-200 relative z-5 overflow-hidden flex justify-center items-center py-3 px-4 text-sm">
                <div class="absolute w-full h-full transition-all duration-300 z-1 group-hover:group-not-active:group-not-disabled:p-1">
                    <div class="w-full h-full rounded-200 transition-all duration-400 bg-transparent group-hover:group-not-disabled:bg-primary-mystic-red-middle"></div>
                </div>
                <div class="inline-flex items-center gap-x-2 relative z-5 w-full md:w-auto justify-center min-w-0">
                    <span class="text-center min-w-0 flex-1 text-primary-mystic-red-standard group-hover:text-neutral-ultralight group-disabled:text-neutral-light">CUSTOMIZE</span>
                </div>
            </div>
        </button>
    </div>
</div>
<div x-data='popupDialog({
				ctaLabel: "",
				ctaTrigger: false,
				target: null,
				dialogId: &#39;cookiesPolicy&#39;,
				open: false,
				ctaAlignment: &#39;undefined&#39;,
				leadershipGridMode: false
			})'
     x-bind:class="ctaAlignment === &#39;center&#39; ? &#39;grid place-content-center place-items-center&#39; : &#39;&#39;">
    <template x-teleport="body">
        <div x-cloak="true" x-show="open" class="dialog-container cookiesPolicy">
            <div class="fixed top-0 left-0 z-40 w-screen h-screen overlay-bg bg-black/60 backdrop-blur-sm"
                 x-transition:enter="transition-opacity ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="transition-opacity ease-in duration-200"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0"></div>
            <div class="fixed inset-0 top-0 left-0 z-50 flex items-center justify-center w-screen h-screen transition-all duration-300 ease-in-out dialog-content">
                <div x-cloak="true"
                     x-show="open"
                     x-data="popupContainer({
									hasOverflow: false,
									isMobile: false,
								})"
                    
                     class="box-border bg-white px-5 md:px-[72px] w-full md:w-auto min-w-[calc(100%-24px)] md:min-w-[468px] md:min-w-[796px] lg:min-w-[796px] md:max-w-[calc(100vw-40px)] lg:min-w-[1002px] lg:max-w-[1002px] rounded-t-2xl md:rounded-2xl fixed bottom-0 md:relative dialog-main"
                     x-on:transitionend="checkOverflow()"
                     x-bind:class="(leadershipGridMode &amp;&amp; hasOverflow) ? &#39;md:mt-20 md:pb-12 md:pt-12&#39; : &#39;pb-12 pt-[72px] md:pt-12&#39;"
                     x-transition:enter="transition ease-out duration-300 transform"
                     x-transition:enter-start="translate-y-full md:translate-y-0 opacity-0"
                     x-transition:enter-end="translate-y-0 opacity-100"
                     x-transition:leave="transition ease-in duration-200 transform"
                     x-transition:leave-start="translate-y-0 opacity-100"
                     x-transition:leave-end="translate-y-full md:translate-y-0 opacity-0">
                    <div class="dialog-close top-5 right-5 md:top-6 md:right-6"
                         x-bind:class="(leadershipGridMode &amp;&amp; hasOverflow) ? &#39;sticky flex justify-end md:absolute&#39; : &#39;absolute&#39;">
                        <span class="hidden md:block">
                            <button type="button"
                                    class="group rounded-full transition-all duration-250 not-disabled:cursor-pointer inline-flex font-bold border border-transparent hover:not-active:not-disabled:border-primary-mystic-red-light rotate-45 rotate-45"
                                    x-on:click="open = false">
                                <div class="bg-button-wrapper transition-all duration-250 rounded-full relative z-5 overflow-hidden flex justify-center items-center py-2 text-sm h-12 w-12">
                                    <div class="absolute w-full h-full transition-all duration-300 z-1 group-hover:group-not-active:group-not-disabled:p-1">
                                        <div class="w-full h-full rounded-full transition-all duration-400 bg-primary-mystic-red-standard group-hover:bg-primary-mystic-red-standard group-active:group-not-disabled:bg-primary-mystic-red-middle group-disabled:bg-neutral-light/30"></div>
                                    </div>
                                    <div class="inline-flex items-center gap-x-2 relative z-5">
                                        <svg width="24"
                                             height="24"
                                             aria-hidden="true"
                                             focusable="false"
                                             class="text-neutral-ultralight group-disabled:text-neutral-light">
                                            <use href="/assets/icons/outlined/sprite.svg#plus" xlink:href="/assets/icons/outlined/sprite.svg#plus" fill="currentColor"></use>
                                        </svg>
                                    </div>
                                </div>
                            </button>
                        </span><span class="block md:hidden">
                            <button type="button"
                                    class="group rounded-full transition-all duration-250 not-disabled:cursor-pointer inline-flex font-bold border border-transparent hover:not-active:not-disabled:border-primary-mystic-red-light rotate-45 rotate-45"
                                    x-on:click="open = false">
                                <div class="bg-button-wrapper transition-all duration-250 rounded-full relative z-5 overflow-hidden flex justify-center items-center py-2 text-sm h-10 w-10">
                                    <div class="absolute w-full h-full transition-all duration-300 z-1 group-hover:group-not-active:group-not-disabled:p-1">
                                        <div class="w-full h-full rounded-full transition-all duration-400 bg-primary-mystic-red-standard group-hover:bg-primary-mystic-red-standard group-active:group-not-disabled:bg-primary-mystic-red-middle group-disabled:bg-neutral-light/30"></div>
                                    </div>
                                    <div class="inline-flex items-center gap-x-2 relative z-5">
                                        <svg width="16"
                                             height="16"
                                             aria-hidden="true"
                                             focusable="false"
                                             class="text-neutral-ultralight group-disabled:text-neutral-light">
                                            <use href="/assets/icons/outlined/sprite.svg#plus" xlink:href="/assets/icons/outlined/sprite.svg#plus" fill="currentColor"></use>
                                        </svg>
                                    </div>
                                </div>
                            </button>
                        </span>
                    </div>
                    <div class="max-h-screen md:max-h-[90vh] overflow-y-auto">
                        <h3 class="heading-3 text-left">Cookies Settings</h3>
                        <div class="my-10">
                            <p class="body-1-semibold text-left">Please set the cookies to your preference</p>
                            <p class="body-1-regular text-left mt-2">Configure your cookie settings and confirm to save your settings. You can withdraw or change your consent at any time on our cookie consent page.</p>
                        </div>
                        <div class="">
                            <div x-data="accordionItemAlone({
                                        open: false,
                                        initialized: false
                                    })"
                                 class="accordion-item w-full rounded-lg border border-neutral-light relative group overflow-hidden">
                                <div x-on:click="handleClick($event)"
                                     x-bind:class="!open ? &#39;group-hover:bg-neutral-extralight&#39; : &#39;&#39;"
                                     class="accordion-header min-h-[40px] inset flex items-center w-full z-1 p-4 gap-4 justify-between cursor-pointer transitions-all duration-300">
                                    <div class="flex items-center">
                                        <div x-data="accordionToggle({ isToggled: true, name: &#39;_necessary&#39; })" class="toggle-container mr-4">
                                            <input type="checkbox"
                                                   id="toggle_necessary"
                                                   class="toggle-checkbox"
                                                   x-model="isToggled"
                                                   disabled
                                                   x-on:change="handleChange" /><label for="toggle_necessary" class="toggle-label"><div class="toggle-knob"></div></label>
                                        </div>
                                        <span class="body-2 font-bold text-neutral-dark md:line-clamp-2">Necessary cookies (Always active)</span>
                                    </div>
                                    <div class="self-start">
