<div class="about_section clearfix">
	<div class="container">
		<div class="main clearfix">
			
			<div class="about_l">
			<iframe width="100%" height="615" src="/template/images/video.mp4" frameborder="0" allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
