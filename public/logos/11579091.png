<script type="text/javascript">
    var _page = "";
    var wow = new WOW(
        {
            boxClass: 'wow',
            animateClass: 'animated',
            offset: 0,
            mobile: true,
            live: true,
            callback: function (box) {
                $(box).css({ "opacity": "1" });

                if ($(box).hasClass("in_05c_an")) {
                    if (!$(box).hasClass("aned")) {
                        if ($(box).attr("data-m") != "") {
                            $(box).find(".p").each(function () {
                                var _thas = $(this);
                                setTimeout(function () {
                                    countup1(_thas.find("span"));
                                }, $(box).attr("data-m"));
                            });
                            $(box).addClass("aned");
                        }
                    }
                }

                if ($(box).closest(".anleft").attr("class") == "anleft") {
                    setTimeout(function () {
                        $(box).addClass("active");
                    }, $(box).attr("data-num"));
                }
                
                
            },
            scrollContainer: null
        }
    );
    wow.init();
</script>
