<script type="text/javascript">
		var banner = new Swiper('.banner .swiper-container', {
		slidesPerView:1,
		spaceBetween: 0,
		loop:false,
		speed:500,
        observer: true,
        autoHeight: true,
		observeParents:true,
			autoplay:{
			delay:3000,
			stopOnLastSlide: false,
			disableOnInteraction: false,

		},
		navigation: {
			nextEl: '.banner .swiper-button-next',
			prevEl: '.banner .swiper-button-prev',
		},
		pagination:{
			el: '.banner .swiper-pagination',
			clickable: true,
		},

		on: {
			slideChangeTransitionStart: function(){
				if(this.activeIndex == 0 ){
					var myVideo= document.getElementById("myvideo");
					myVideo.baseURI="./images/video.mp4";
					myVideo.load();
					myVideo.play();
				}
			},
		},

	});

	$(".banner .swiper-slide-active video").on('play', function() { // 播放中
		banner.autoplay.stop();
		// banner.stopAutoplay(); //停止轮播图轮播
	});
	$(".banner .swiper-slide-active video").on('timeupdate', function() { // 播放中
		this.setAttribute('controls', true);
	});
	$(".banner .swiper-slide-active video").on('pause', function() { // 暂停时
		banner.autoplay.start();
	});
	$(".banner .swiper-slide-active video").on('ended', function() { // 结束时
		banner.autoplay.start();
	});


</script>

<script src="./request/common.js?v=1.0.0"></script>
<script>
	getMedia();

	function getMedia() {
		var totalData = [];
		var noTopData = {
			informationType: 'CompanyDynamicNews',
			pageindex: 1,
			pagesize: 5,
			language: 'Chinese'
		};
		var parmas = {
			informationType: 'CompanyDynamicNews',
			language: 'Chinese',
			isPush: true,
			pageindex: 1,
			pagesize: 2
		};
		var newsList;
		var companyList;
		request.post(parmas).then(function (res2) {
			newsList = res2.data;
			request.post(noTopData).then(function (res) {
				totalData = res.data;
				totalData.forEach(function (j) {
					j.sendTime = dayjs(j.sendTime, "YYYY/MM/DD HH:mm:ss").toDate().getTime();
				});

				function sortList(a, b) {
					return a.sendTime - b.sendTime;
				}

				totalData = totalData.sort(sortList).reverse();
				var times = totalData.map(function (item) {
					return item.sendTime;
				});
				var newsData = totalData;
				var listRightData = [];

				for (var item = 0; item < newsData.length && item < 5; item++) {
					listRightData.push(newsData[item]);
					var formation = new Date(newsData[item].sendTime);
					var y = formation.getFullYear();
					var m = formation.getMonth() + 1;
					var d = formation.getDate();

					var temple = "<div class=\"text text1\"><a href=\"madio2.html?id=''&type=3\" class=\"clearfix\" ><div class=\"p\">".concat(y, ".").concat(m, ".").concat(d, "</div><div class=\"h\">").concat(newsData[item].title, "</div></a></div>");
					$('#comNoTop').append(temple);
				}

				totalData.slice(0);
				$('#comNoTop .text').on('click', function () {
					var index = $('#comNoTop .text').index(this);
					window.localStorage.setItem('indexRightList', JSON.stringify(listRightData[index]));
				}); // 左侧大图

				var listNewsData = newsList;
				listNewsData.reverse();

				for (var j = 0; j < listNewsData.length; j++) {
					var formation = new Date(listNewsData[j].sendTime);
					var y = formation.getFullYear();
					var m = formation.getMonth() + 1;
					var d = formation.getDate();
					var temple = "<div class=\"box wow \" data-wow-duration=\"1s\"><a href=\"madio2.html?id=''type=0\" class=\"clearfix\"><div class=\"img\"><img src=\"".concat(listNewsData[j].titlePic, "\" alt=\"\"></div><div class=\"text\"><div class=\"h\">").concat(listNewsData[j].title, "</div><div class=\"p\">").concat(y, ".").concat(m, ".").concat(d, "</div></div></a></div>");
					$('#mediaCenter').prepend(temple);
				}

				$('#mediaCenter .box').on('click', function () {
					var index = $('#mediaCenter .box').index(this);
					window.localStorage.setItem('pronewsData', JSON.stringify(listNewsData.reverse()[index]));
				});
			});
		});
	}

	function compare(val) {
		return function (a, b) {
			var value1 = a[val];
			var value2 = b[val];
			return value1 - value2;
		};
	}
</script>
<script src="js/lang.js?v=20250115"></script>
<script>
	//当从英文版点击繁体版返回时，获取参数并转换成繁体，不带参数默认是简体
	var langParmas = window.location.href.split('?')[1]
	if (langParmas) {
		var lang = langParmas.split('=')[1]
		zh_tran(lang);
	}
</script>
