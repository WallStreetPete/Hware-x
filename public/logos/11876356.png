    <script>
        var mySwiper = new Swiper('.banner .swiper-container', {
            pagination: '.banner .pagination',
            paginationClickable: true,
            keyboardControl: true,
            autoplay: 6000,
            speed: 600,
            loop: true,
            calculateHeight: true,
            resizeReInit: true
        })

        var mySwiperNews = new Swiper('.index-hot .swiper-container', {
            pagination: '.index-hot .pagination',
            mode: 'vertical',
            paginationClickable: true,
            keyboardControl: true,
            autoplay: 5000,
            speed: 600,
            loop: true,
            calculateHeight: true,
            resizeReInit: true
        })

        $(".index-hot a.prev_btn").click(function () {
            mySwiperNews.swipePrev();
        })

        $(".index-hot a.next_btn").click(function () {
            mySwiperNews.swipeNext();
        })
        $(".index-product-2 .index-product-body .list").hide();
        $(".index-product-2 .index-product-body .list:eq(0)").show();
        $(".index-product-2 .index-product-header a").mouseover(function () {
            var thisIndex = $(this).index();
            $(this).addClass("active").siblings("a").removeClass("active");
            $(".index-product-2 .index-product-body .list:eq(" + thisIndex + ")").show().siblings(".list").hide();
        })

        $(".index-news .index-news-body .list").hide();
        $(".index-news .index-news-body .list:eq(0)").show();
        $(".index-news .index-news-header a").mouseover(function () {
