    <script language="javascript">
        var thumbsSwiper = new Swiper('.data-shortcuts-circle .swiper', {
            spaceBetween: 30,
            slidesPerView: 3,
            watchSlidesVisibility: true, //防止不可点击
            breakpoints: {

                1280: {
                    spaceBetween: 20,
                    centerInsufficientSlides: true,
                    // centeredSlides: true,
                    direction: "vertical",
                },

            },
        })
        var gallerySwiper = new Swiper('.data-shortcuts-info .swiper', {
            spaceBetween: 30,
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
            },
            thumbs: {
                swiper: thumbsSwiper,
            },
            breakpoints: {
                1280: {
                    // centeredSlides: true,
                },

            },
        })
    </script>

