            <!--更多西勝相關訊息-->
        <section>
            <div class="l-wrapper-large rel pt:20 pb:60 {pt:50;pb:100}@sm pb:120@lg">
                <h2 data-aos="fade-up" data-aos-delay="250" class="f:32 f:40@sm f:45@md mb:52 mb:40@sm mb:70@lg f:medium"> 更多<span class="f:primary">西勝</span>相關訊息</h2>
                <div class="flex flex:column {flex;flex:nowrap;flex:row;jc:space-between;gap:30}@md gap:80@lg ">

                                        <a href="tw/news/detail/ctech__a_legacy_of_innovation" data-aos="fade-up" data-aos-delay="500" class="block {w:full}:hover_.more:before {f:primary;~color|.3s}:hover>div>h5 {translate(-50%,-50%)|scale(1.1);~transform|.5s}:hover>div>p>img {w:61.458%;flex;flex:nowrap;jc:space-between;}@md">
                        <div class="rel mb:30 {w:49.152%;mb:0}@md">
                            <p class="f:20 lh:1"><span class="f:bold f:primary default-font-en">2025.01.08</span><span
                                    class="px:10 f:gray/0.6">|</span><span class="f:black/0.5">公司訊息</span></p>
                            <h5 class="mt:15 mb:30 f:24 f:medium lh:1.5">CTECH: A Legacy of Innovation                            </h5>
                            <p class="pb:40 pb:0@md">With a dedicated team and complete control over the supply chain system, we ensure high-volume, stable production. By employing the most efficient processing methods and implementing flawless quality management practices, our production lines operate smoothly without overloading. This guarantees on-time delivery and the highest quality products for our valued customers.<br />
<br />
