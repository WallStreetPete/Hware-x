            <td width="50%" rowspan="3" align="left" valign="middle"><iframe width="100%" height="330" src="https://www.youtube.com/embed/NMTIaE6xkKY?si=QRJPUOUxFA2AHAcl" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe></td>
