<style>
.swiper-container {position: relative; width: 100%; height: 100%;}
.swiper-slide {overflow: hidden;}
.swiper-slide img {max-width:100%; width:100%; height:auto;}
.swiper-slide .slide_txt {margin: 0 auto; display: flex; justify-content: center; flex-direction: column; height: 100%; color: #fff;}
.swiper-slide .slide_txt h3 {font-size: 70px; font-weight: 300; line-height: 1.1428;}
.swiper-slide .slide_txt .txt_st1 {margin:22px 0 50px; line-height: 1.8;}

/* 양쪽 화살표 이미지 변경하기*/
.swiper-button-prev, .swiper-button-next {width: 38px; height: 71px; background-size: cover; top: 53%;}
.swiper-button-prev, .swiper-container-rtl .swiper-button-next {background-image: url(https://rf-materials.com/theme/responsive_rfmaterials/skin/latest/slide_basic_01/slide-prev.png) !important; left: 3.5% !important;}
.swiper-button-next, .swiper-container-rtl .swiper-button-prev {background-image: url(https://rf-materials.com/theme/responsive_rfmaterials/skin/latest/slide_basic_01/slide-next.png) !important; right: 3.5% !important;}
/* Swiper 화살표 끝*/

/* pagination 커스텀 시작*/
.swiper-pagination-bullet {position: relative; width: 10px; height: 10px; text-align: center; line-height: 20px; font-size: 12px; color:#000 !important; opacity: 1; background: rgba(255,255,255,0.7);}
.swiper-pagination-bullet:before {position: absolute; left:50%; top:50%; transform:translate(-50%, -50%); content:''; width: 0; height: 0; border-radius:100%; border:1px solid #fff; opacity: 0; visibility:hidden; transition:.3s ease all;}
.swiper-pagination-bullet-active {background: #fff;}
.swiper-pagination-bullet-active:before {width: 45px; height: 45px; opacity: 1; visibility:visible;}
/* pagination 커스텀 끝*/

.line_ani {position: absolute; left: 15.4%; bottom: 0;  z-index: 10; overflow: hidden;}
.line_ani .dot {width: 4px; height: 4px; border-radius:100%; background-color: #fff;}
.line_ani .line {margin-left: 1px; width: 2px; height: 150px; margin-top: 4px; background-color: rgba(255,255,255,0.5); overflow: hidden;}
.line_ani .line:before {display: inline-block; content:''; width: 2px; height: 50px; background-color: #fff; animation: lineAni 1.5s infinite;}
@keyframes lineAni {
	0% {transform:translateY(-300%);}
	100% {transform:translateY(300%);}
}

@media(max-width: 1600px){
	.swiper-button-prev, .swiper-container-rtl .swiper-button-next {left: 0 !important;}
	.swiper-button-next, .swiper-container-rtl .swiper-button-prev {right: 0 !important;}
	.swiper-button-prev, .swiper-button-next {width: 28px; height: 50px;}
}
@media(max-width: 1080px){
	.swiper-button-prev, .swiper-button-next {display: none;}
	.swiper-slide .slide_txt h3 {font-size: 58px;}
	.swiper-pagination-bullet {width: 8px; height: 8px;}
	.swiper-pagination-bullet-active:before {width: 40px; height: 40px;}
	.swiper-slide .slide_txt .txt_st1 {width: 85%;}
	.swiper-slide .slide_txt .txt_st1 br {display: none;}
}
@media(max-width: 768px){
	.swiper-slide .slide_txt h3 {font-size: 46px;}
	.swiper-pagination-bullet {width: 6px; height: 6px;}
	.swiper-pagination-bullet-active:before {width: 35px; height: 35px;}
	.line_ani .line {height: 110px;}
}
@media(max-width: 500px){
	.swiper-slide .slide_txt h3 {font-size: 34px;}
	.swiper-pagination-bullet {width: 4px; height: 4px;}
	.swiper-pagination-bullet-active:before {width: 30px; height: 30px;}
}

</style>

<div class="swiper-container">
