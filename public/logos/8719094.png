	// Init Swiper
	var mswiper = new Swiper('.swiper-container', {
		slidesPerView: 1,							// 동시에 보여줄 슬라이드 갯수
    	slidesPerGroup: 1,						// 그룹으로 묶을 갯수, Sideperview 와 갯수와 똑같이할때 추천
		effect: 'slide',							// 효과 바꾸기 "slide", "fade", "cube", "coverflow", "flip"
		loop: true,										// 슬라이드 연속시 true, 비연속시 false
		speed:1000,
		autoplay: {		//slide auto
			delay: 8000,
			disableOnInteraction: false
		},
		pagination: {
			el: '.swiper-pagination',
			clickable: true,
		},
		navigation: {
			nextEl: '.swiper-button-next',	// 이전 버튼 클래스명
			prevEl: '.swiper-button-prev',	// 이전 버튼 클래스명
		},
		on: {
			slideChangeTransitionStart: function () {
				$('.slide_txt h3').hide(0);
				$('.slide_txt h3').removeClass('aos-init').removeClass('aos-animate');
				$('.slide_txt p').hide(0);
				$('.slide_txt p').removeClass('aos-init').removeClass('aos-animate');
			},
			slideChangeTransitionEnd: function () {
				$('.slide_txt h3').show(0);
				$('.slide_txt h3').addClass('aos-animate');
				$('.slide_txt p').show(0);
				$('.slide_txt p').addClass('aos-animate');
			},
		}

	});
</script>
