<script>
$('.header_gnb_bg').mouseenter(function(){
	$('.header_t').addClass("f-nav");
}).mouseleave(function(){
	$('.header_t').removeClass("f-nav");
});

var a_table = ['sec1', 'sec2', 'sec3', 'sec4', 'sec5'];

$('#fullpage').fullpage({
	anchors:a_table,
	onLeave: function(index, nextIndex, direction){
		for (var i = 0; i < a_table.length; i++) {
			$('.'+ a_table[i] +'.active').find("[data-aos]").removeClass('aos-init').removeClass('aos-animate');
		}

		$("#m_menu li").removeClass("active");
		$("#m_menu li").eq(nextIndex.index).addClass("active");
		
		if(nextIndex.index == 0){
			$('.header_t').removeClass("f-nav")
			$('.header_gnb_bg').mouseenter(function(){
				$('.header_t').addClass("f-nav");
			}).mouseleave(function(){
				$('.header_t').removeClass("f-nav");
			});
		}else if(nextIndex.index == 1){
			$('.header_t').addClass("f-nav")
			$('.header_gnb_bg').mouseenter(function(){
				$('.header_t').addClass("f-nav");
			}).mouseleave(function(){
				$('.header_t').addClass("f-nav");
			});
		}else if(nextIndex.index == 2){
			$('.header_gnb_bg').mouseenter(function(){
				$('.header_t').addClass("f-nav");
			}).mouseleave(function(){
				$('.header_t').removeClass("f-nav");
			});
		}
	},
	afterLoad: function(){       
		for (var i = 0; i < a_table.length; i++) {
			$('.'+ a_table[i] +'.active').find("[data-aos]").addClass('aos-animate');
		}
	},
	
	verticalCentered: true,
	//scrollOverflow: true,
	responsiveWidth: 768
});

$(function(){
	const bgList = $('.sec2 .ct_list li');
	const bgImg = $('.sec2 .ct_list div figure');
	console.log(bgList);
	console.log(bgImg);

	bgList.mouseover(function(){
		$(this).each(function(){
			let cnt = $(this).index();

			bgImg.removeClass('on');
			bgImg.eq(cnt).addClass('on');
		});
	});

})
</script><!-- 하단 시작 { -->
