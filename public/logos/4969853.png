<script>
var g5_cookie_domain = "";
</script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery-cookie/1.4.1/jquery.cookie.min.js"></script>
<script src="https://wooritg.com/admin/js/common.js?ver=210618"></script>
<script>
$(function() {
    $('.button__reject').on('click', function() {
        const id = $(this).closest('.popup').attr('id');
        set_cookie(id, 1, 1, g5_cookie_domain);
        $(this).closest('.popup').hide();
    });
    $('.button__close').on('click', function() {
        $(this).closest('.popup').hide();
    });

    const popup = $('.popup');

    function checkPosition() {
        if (popup.length == 0) return;
        let $left = popup.offset().left;
        let $width = popup.width();
        let $delta = $left + $width;
        let winWidth = $(window).width();

        if ($delta > winWidth) {
            popup.css({'left' : 'auto', 'right' : '20px'});
        }
    }

    $(document).ready(function() {
        checkPosition();
        $(window).on('resize', function() {
            checkPosition();
        });
    });

});

</script>
