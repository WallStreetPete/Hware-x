<style>
    .header-wrap {
        display: none !important;
    }


    footer {
        display: none !important;
    }

    /* 修改 grid-1-2 類別的樣式 */
    .grid-1-2 {
      display: grid;
      grid-gap: 60px;
      grid-template-columns: 1fr 2fr;
      grid-auto-rows: 150px;
      grid-auto-flow: row dense;
      max-width: 1250px;
      width: 100%;
      margin: 30px auto 0;
      box-sizing: border-box;

      /* 確保填滿網格區域 */
      justify-items: stretch;
      align-items: stretch;
    }

    /* 左側元素 */
    .left-column {
      grid-row-end: span 2;
      /* 高度為兩個基本單位 */
    }

    /* 右側輪播 */
    .right-column {
      grid-row-end: span 2;
      /* 確保輪播區域高度與左側相同 */
      transform: translateX(-30px); /* 向左偏移 30px，可以根據需要調整數值 */
      width: calc(100% + 30px); /* 增加寬度，補償左移後右側可能出現的空白 補償左偏移(-60px)並增加右延伸(+30px)*/
      margin-right: -30px; /* 向右擴展，確保內容能夠延伸到右邊緣 */
    }

    /* 右側輪播 */
    .carousel-container {
      position: relative;
    }

    /* 讓輪播內的圖片填滿容器 */
    .carousel-container .carousel,
    .carousel-container .carousel-inner,
    .carousel-container .carousel-item {
      height: 100%;
    }

    .carousel-container .carousel-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    @media (max-width: 768px) {
      .grid {
        grid-template-columns: 1fr;
        /* 小螢幕上變為單列 */
      }

      .grid-1-2 {
        grid-template-columns: 1fr;
        /* 小螢幕上變為單列 */
        grid-gap: 30px; /* 減少間距，從 60px 減小到 30px */
        margin:30px auto 0;
      }

      .right-column {
        width: 100%; /* 恢復正常寬度 */
        margin-right: 0;
        transform: none;
      }
    }

    @media (max-width: 768px) {
      .grid {
        grid-gap: 30px; /* 調整手機版間距 */
        grid-template-columns: 1fr; /* 改為單列布局 */
      }

      /* 添加手機版 item 高度調整 */
      .grid .item {
        grid-row-end: span 1; /* 確保所有 item 在手機版只佔一個單位高度 */
        height: 10rem; /* 設定適合手機版的固定高度 */
      }

      .grid .item--medium,
      .grid .item--large {
        grid-row-end: span 1; /* 覆蓋原本的 span 設定 */
      }

      /* 調整手機版內容物間距 */
      .item__details {
        padding: 8px;
      }

      /* 調整手機版標題大小 */
      .item__details h1 {
        font-size: 1.6rem;
        margin-bottom: 0;
      }
    }
    /* 在現有的 CSS 樣式中添加以下代碼 */
    @media (max-width: 768px) {
      /* 手機版隱藏輪播控制按鈕 */
      .carousel-control-prev,
      .carousel-control-next {
        display: none;
      }
    }
    /* 增加輪播控制按鈕的 z-index，使其高於 item 的連結 */
    .carousel-control-prev,
    .carousel-control-next {
        z-index: 5; /* 高於 item a 的 z-index: 2 */
    }

    /*圓點指示器顏色*/
    .carousel-indicators button {
        background-color: #999; /* 預設灰色 */
        width: 12px;
        height: 12px;
        border-radius: 50%;
        opacity: 0.5;
    }

    .carousel-indicators .active {
        background-color: gray; /* 當前選中的圓點顏色 */
        opacity: 1;
    }

    /* RWD 影片容器：有高度、不被覆蓋 */
    .video-box {
        position: relative;
        width: 100%;
        height: 0;
        padding-bottom: 56.25%; /* 16:9，可改 65%、70% 想更高 */
        background: #000;
        overflow: hidden;
        z-index: 1; /* 確保在覆蓋層之上 */
    }

        .video-box iframe {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
            object-fit: cover; /* 電腦版不留黑邊（會略裁切） */
            pointer-events: auto;
        }

        /* 若你的 .item 有全覆蓋連結或 ::after，避免它干擾影片點擊 */
        .video-box a {
            display: none !important;
        }

        .video-box::after {
            content: none !important;
        }

    /* 桌機想更滿可以加高（選用） */
    @media (min-width: 768px) {
        .video-box {
            height: 80vh;
            padding-bottom: 0;

        }
        /* 或改成 height:80vh; padding-bottom:0; */


    }
    /* 影片區寬度與上方 grid 對齊 */
    .video-section {
        max-width: 1250px; /* 與 .grid 一致 */
        width: 100%;
        margin: 0 auto; /* 置中 */
        margin-bottom: clamp(60px, 8vh, 120px); /* 自適應下方留白 */
    }

    /* 影片容器，確保有高度 */
    .video-box {
        position: relative;
        width: 100%;
        height: 0;
        padding-bottom: 56.25%; /* 16:9 */
        background: #000;
        overflow: hidden;
        z-index: 1;
    }

        .video-box iframe {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
            object-fit: cover; /* 電腦不留黑邊（會略裁切） */
            pointer-events: auto;
        }

    /* 桌機想更高就用視窗高；保留 @media 給 Razor */
    @media (min-width: 992px) {
        .video-box {
            padding-bottom: 0; /* 停用 16:9 */
            height: 70vh; /* 可改 80vh 看喜好 */
        }
    }

    /* 手機下方留白稍微小一點 */
    @media (max-width: 768px) {
        .video-section {
            margin-bottom: 50px;
        }
    }

</style>

