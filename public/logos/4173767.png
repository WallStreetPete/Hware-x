<script>
    window.addEventListener('DOMContentLoaded', function() {
        //最新ニューススライダー
        if (document.querySelectorAll('.news-swiper-wrapper .swiper-slide').length > 1) {
          var mySwiper = new Swiper('.news-swiper-wrapper', {
              direction: 'vertical',
              loop: true,
              autoplay: {
                  delay: 5000,
              },
          });
        }
        // ニュース枠2列対応
        const addTagElm = document.querySelector('.block-news-area');
        if (addTagElm) {
            const newsElm = document.querySelectorAll('.block-news-area');

            elemlist = '<section class="layout-columns layout-columns-2 inner-frame"><ul id="js-add-news" class="layout-columns-2-list"></ul></section>';
            addTagElm.insertAdjacentHTML('beforebegin', elemlist);

            newsElm.forEach(function(e,i){
                document.getElementById('js-add-news').insertAdjacentHTML('beforeend', '<li />');
                document.querySelector('#js-add-news li:empty').appendChild(e);
            });
        }
    });
</script>

