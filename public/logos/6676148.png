		<!-- 加载js文件-->
		<script type="text/javascript" src="https://res.wx.qq.com/open/js/jweixin-1.4.0.js"></script>
		<script type="text/javascript" src="/static/js/vidbg.min.js"></script>
		<script type="text/javascript" src="/static/layui/layui.js"></script>
		<script type="text/javascript" src="/static/js/jquery.SuperSlide.2.1.1.js"></script>
		<script>
			if($('.xy-phone').length>0){
				let str = '<video id="customer_video" class="video-background" preload="auto" loop playsinline autoplay src="/static/video/index3.mp4" tabindex="-1" muted="muted" x5-video-player-type="h5"></video>';
				$('.section-second').append(str);
				document.getElementById('customer_video').play();
				//必须在微信Weixin JSAPI的WeixinJSBridgeReady才能生效
				document.addEventListener("WeixinJSBridgeReady", function () {
					document.getElementById('customer_video').play();
				}, false);
				document.addEventListener('touchstart', function() {
					var video = document.getElementById("ckplayer_a1");
					video.play();
				},false);
				}else{
				jQuery(function($) {
					$('.section-second').vidbg({
						'mp4': '/static/video/index3.mp4',
					}, {
						// Options
						muted: true,
						loop: true,
						overlay: true,
					});
				});
			}

            $(document).scroll(function() {
                var scroH = $(document).scrollTop(); //滚动高度
                var viewH = $(window).height(); //可见高度
                var contentH = $(document).height(); //内容高度

                // if (scroH >= 680) { //距离顶部大于680px时
                //     // $('.logo h1').show();
                //     $('.logo h2').hide();
                //     $('.logo h1').removeClass('hide');
                //     $('.logo h2').addClass('hide');
                // } else {
                //     $('.logo h1').hide();
                //     $('.logo h1').addClass('hide');
                //     $('.logo h2').removeClass('hide');
                //     $('.logo h2').show();
                // }
            });

            $(function() {
                var t = 3000;
                //每隔两秒进行一次滚动
                var timing = setInterval("info()", t);
                $("#fontul .lifont").hover(
                    function() {
                        clearInterval(timing);
                    },
                    function() {
                        timing = setInterval("info()", t);
                    }
                )
            });

            function info() {
                //复制第一个li
                var lia = $("#fontul .lifont:eq(0)").clone();
                $("#fontul .lifont:eq(0)").animate({
                    marginTop: "-60px"
                }, 500, function() {
                    //对已经消失的li进行删除
                    $("#fontul .lifont:eq(0)").remove();
                    //把复制后的li插入到最后
                    $("#fontul").append(lia);
                });
            }
            //slide box
            $(".xy-pc .slide-item-box").slide({
                titCell: ".hd ul",
                mainCell: ".bd ul",
                autoPage: true,
                effect: "leftLoop",
                autoPlay: true,
                scroll: 3,
                vis: 3,
                delayTime: 700,
                trigger: "click"
            })
			$(".xy-phone .slide-item-box").slide({
				titCell: ".hd ul",
				mainCell: ".bd ul",
				autoPage: true,
				effect: "leftLoop",
				autoPlay: true,
				scroll: 1,
				vis: 1,
				delayTime: 700,
				trigger: "click"
			})

            document.body.addEventListener('touchstart', function(){ });
            // 禁用or启用背景滑动  isDiff默认为flase是可以滑动，为true是不可以滑动。
            var isDiff = false;
            var overscroll = function(el){
                el.addEventListener('touchstart', function(){
                    var top = el.scrollTop;
                    var totalScroll = el.scrollHeight;
                    var currentScroll = top + el.offsetHeight;
                    if(top === 0) {
                        el.scrollTop = 1;
                    }else if(currentScroll === totalScroll){
                        el.scrollTop = top - 1;
                    }
                });
                el.addEventListener('touchmove', function(evt){
                    if(el.offsetHeight < el.scrollHeight){
                        evt._isScroller = true;
                    }
                });
            }
            document.body.addEventListener('touchmove', function(evt) {
                if(isDiff && !evt._isScroller){
                    evt.preventDefault();
                }
            }, {passive: false});

            function a(){
                var minX = {number:999999,object:null};
                $('.history-main-box').each(function (){
                    if(minX.number > Math.abs( $(this).offset().left -$('.history-content .mod-con').offset().left)){
                        minX.number =  Math.abs( $(this).offset().left -$('.history-content .mod-con').offset().left) ;
                        minX.object = this;
                    }
                });
                $('.progress-bar .node').each(function (index){
                    if($(this).data('year') == $(minX.object).attr('year')){
                        $('.progress-bar .node').removeClass('active')
                        $(this).addClass('active')
                    }
                });


                var bi = (Math.abs($('.history-main').css('left').split('px')[0])/( ($('.history-main-box').width()+$('.history-main-box').css('margin-right').split('p')[0]*1) * ($('.history-main-box').length - 1  )  ) );

                $('.history-button .focus').css('width',bi*100+'%');
            }

            $('.mod-con .history-main').mousedown(function(e) {
                var positionDiv = $(this).offset();
                var distenceX = e.pageX;
                var startX = $('.mod-con .history-main')[0].style.left.split('px')[0]*1;
                $(document).mousemove(function(e) {
                    var x =  startX+(e.pageX - distenceX);
                    if(x>0){
                        x = 0;
                    }
                    if(x<-( ($('.history-main-box').width()+$('.history-main-box').css('margin-right').split('p')[0]*1)    * ($('.history-main-box').length - 1)  ) ){
                        x = -( ($('.history-main-box').width()+$('.history-main-box').css('margin-right').split('p')[0]*1) * ($('.history-main-box').length - 1  )  );
                    }
                    $('.mod-con .history-main').css({
                        'left': x + 'px',
                    });
                    a();
                });

                $(document).mouseup(function() {
                    $(document).off('mousemove');
                });
            });

            $('.mod-con .history-main')[0].ontouchstart = function(e) {

                var positionDiv = $(this).offset();
                var distenceX = e.touches[0].pageX;
                var startX = $('.mod-con .history-main')[0].style.left.split('px')[0]*1;
                $(document)[0].ontouchmove = function(e) {
                    var x =  startX+(e.touches[0].pageX - distenceX);
                    if(x>0){
                        x = 0;
                    }
                    if(x<-( ($('.history-main-box').width()+$('.history-main-box').css('margin-right').split('p')[0]*1)    * ($('.history-main-box').length - 1)  ) ){
                        x = -( ($('.history-main-box').width()+$('.history-main-box').css('margin-right').split('p')[0]*1) * ($('.history-main-box').length - 1  )  );
                    }
                    $('.mod-con .history-main').css({
                        'left': x + 'px',
                    });
                    a();
                }

                $(document)[0].ontouchend = function() {
                    $(document)[0].ontouchmove = function (){};
                }
            }



            function activeHistory(key){
                var yearEle = $('[year="'+key+'"]');

                var left = 0;

                if (yearEle.offset()) {
                    let curretYearOffset = $('[year="'+ 2024 +'"]').offset() ? $('[year="'+ 2024 +'"]').offset().left :  $('[year=2024]').offset().left;
                    left = $('[year="'+key+'"]').offset().left - curretYearOffset;
                }

                $('.history-main').css({'left':'-'+left+'px'});

                $('.progress-bar .node').each(function (index){
                    if($(this).data('year') == key){
                        $('.progress-bar .node').removeClass('active')
                        $(this).addClass('active')
                    }
                });
                a();
            }

            var lang = window.location.pathname.match(/^\/(zh\-(cn|hk)|en\-us)/);
            lang = lang ? lang[1] : 'zh-cn';
            var montext = '月';
            if(lang == 'en-us'){
                montext = '';
            }else{
                montext = '月';
            }


            let histData = {
                "zh-cn": {
					"2024":[
						{
							"month":"1",
							"text":"控股子公司“富羿”成立"
						},
						{
							"month":"5",
							"text":"坪山分公司成立"
						},
						{
							"month":"12",
							"text":"福田分公司成立"
						},
					],
                    "2021":[
                        {
                            "month":"10",
                            "text":"公司证券简称由“富满电子”变更为“富满微”"
                        },
                        {
                            "month":"12",
                            "text":"公司2021年创业板向特定对象发行A股股票上市"
                        },
                    ],
                    "2020":[
                        {
                            "month":"1",
                            "text":"控股子公司“台慧微”成立"
                        },
                        {
                            "month":"3",
                            "text":"控股子公司“佳满鑫”成立"
                        },
                        {
                            "month":"6",
                            "text":"公司首次非公开发行A股股票上市"
                        },
                        {
                            "month":"11",
                            "text":"公司更名为“富满微电子集团股份有限公司”"
                        }
                    ],
                    "2018":[
                        {
                            "month":"10",
                            "text":"全资子公司“富满合肥”成立"
                        },

                    ],
                    "2017":[
                        {
                            "month":"7",
                            "text":"深交所创业板挂牌上市"
                        },
                        {
                            "month":"11",
                            "text":"控股子公司“凌矽半导体”成立"
                        },
                    ],
                    "2015":[
                        {
                            "month":"4",
                            "text":"控股子公司“云矽半导体”成立"
                        },
                    ],
                    "2014":[
                        {
                            "month":"7",
                            "text":"富满电子完成股份制改造暨深圳市富满电子集团股份有限公司成立"
                        }
                    ],
                    "2012":[
                        {
                            "month":"1",
                            "text":"富满电子有限公司观澜分公司封装测试厂成立"
                        },
                        {
                            "month":"3",
                            "text":"富满电子全资子公司“鑫恒富”成立"
                        }
                        ,
                        {
                            "month":"4",
                            "text":"富满电子全资子公司“富玺香港”成立"
                        }
                    ],
                    "2010":[
                        {
                            "month":"9",
                            "text":"富满电子有限公司南山分公司成立"
                        }
                    ],
                    "2001":[
                        {
                            "month":"11",
                            "text":"富满电子有限公司成立"
                        }
                    ]
                }

            }

            for(var k in histData[lang]){
                var html = '<div class="history-main-box" year="'+k+'">';
                html += '<div class="history-title">'+k+'</div>';
                for(var key in histData[lang][k]){
                    html += '<div class="li"><div class="left">'+histData[lang][k][key].month+montext+'</div><div class="right">'+histData[lang][k][key].text+'</div><div class="both"></div></div>';
                }
                html += '</div>';
                $('.history-main').prepend(html);
            }

            activeHistory(2022);



            $('.history-button img').click(function (){

                var minX = {number:999999,object:null};

                $('.history-main-box').each(function (){
                    if(minX.number > Math.abs( $(this).offset().left -$('.history-content .mod-con').offset().left)){
                        minX.number =  Math.abs( $(this).offset().left -$('.history-content .mod-con').offset().left) ;
                        minX.object = this;
                    }
                });
                var objI = 0;
                if($(this).data('direction') == 'left'){
                    objI = $(minX.object).index()*1-1;
                }else{
                    objI = $(minX.object).index()*1+1;
                }

                if($('.history-main-box').eq(objI)[0]){
                    activeHistory($('.history-main-box').eq(objI).attr('year'));
                }
            });


            $('.progress-bar .node').each(function (index){
                $(this).attr('index',index)
                $(this).click(function (){
                    activeHistory($(this).data('year'))
                });
            })

            var historyHarr = [];
            function historyMinHeightFun(){
                setTimeout(function(){
                    historyHarr = [];
                    $('.history-main-box').each(function(){
                        historyHarr.push($(this).height());
                    })
                    var maxHeight = Math.max.apply(null, historyHarr);
                    $('.history-content').css('height',maxHeight+15+'px');
                },100);
            }
            historyMinHeightFun();


            $(window).resize(function () {
                historyMinHeightFun();
            })


            $('.framework-box .list-ul .li').on('click',function(){
                $('.framework-box .list-ul .li').removeClass('active-li');
                $('.framework-box .li-mess-box .mess-text').removeClass('active-mess');
                $(this).addClass('active-li');
                $('.framework-box .li-mess-box .mess-text').eq($(this).index()).addClass('active-mess');
            })

            $('.team-pop .pop-box .close').on('click',function(){
                $('.team-pop').hide();
                isDiff = false;
            })

		</script>
	</body>

</html>
