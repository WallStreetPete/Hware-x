<script>
    $('#phone_menu').on('click',function(){
        if($(this).hasClass('larry-zhankaicaidan')){
            $(this).addClass('larry-shouqicaidan').removeClass('larry-zhankaicaidan');
            $(this).parent('.nav').addClass('menu-show');
            $(this).siblings('.menu_list').removeClass('menu_list_fold');
            $(this).siblings('.menu_list').addClass('menu_list_open');
        }else{
            $(this).addClass('larry-zhankaicaidan').removeClass('arry-shouqicaidan');
            $(this).parent('.nav').removeClass('menu-show');
            $(this).siblings('.menu_list').removeClass('menu_list_open');
            $(this).siblings('.menu_list').addClass('menu_list_fold');
        }
    })
</script>
