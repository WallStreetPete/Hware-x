<script type="text/javascript">
   window.onscroll=function(){ 
       var t=document.documentElement.scrollTop||document.body.scrollTop;  
       var dh2=document.getElementById("dh2"); 
       if(t>= 200){ 
           dh2.className = "dh2_1";
       }else{
           dh2.className = "dh2";
       } 
   }


 // 等待 DOM 加载完成
 document.addEventListener('DOMContentLoaded', function() {
       // 获取所有 .d_a 元素
       const dAs = document.querySelectorAll('.dh2 .icenter .pcnav dd .d_a');
       
       // 为每个 .d_a 元素添加点击事件
       dAs.forEach(dA => {
           dA.addEventListener('click', function(e) {
               e.preventDefault();
               // 移除所有 .d_a 的 .act 类
               dAs.forEach(item => item.classList.remove('act'));
               // 为当前点击的 .d_a 添加 .act 类
               this.classList.add('act');

               // 获取所有 .downav 元素
               const downAvs = document.querySelectorAll('.dh2 .icenter .pcnav dd .downav');
               // 隐藏所有 .downav 并移除 .atto 类
               downAvs.forEach(item => {
                   item.style.display = 'none';
                   item.classList.remove('atto');
               });

               // 显示当前点击的 .d_a 同级的 .downav 并添加 .atto 类
               const siblingDownAv = this.parentElement.querySelector('.downav');
               siblingDownAv.style.display = 'block';
               siblingDownAv.classList.add('atto');
           });
       });

       // 点击空白区域关闭 .downav
       document.addEventListener('click', function(e) {
           if (!e.target.closest('.dh2 .icenter .pcnav dd .d_a') && !e.target.closest('.dh2 .icenter .pcnav dd .downav .webnavd_code')) {
               const downAvs = document.querySelectorAll('.dh2 .icenter .pcnav dd .downav');
               downAvs.forEach(item => {
                   item.style.display = 'none';
                   item.classList.remove('atto');
               });
               dAs.forEach(item => item.classList.remove('act'));
           }
       });
   });
   
</script>

















