<script>
    document.addEventListener('DOMContentLoaded', function() {
      const homeBarSearch = document.querySelector('.home_bar_search');
      const ca = document.querySelector('.home_bar_search .ca');
      const cb = document.querySelector('.home_bar_search .cb');
      const protb = document.querySelector('.home_bar_search .ca .tb .b1 .webs_procat .protb');
  
      ca.addEventListener('click', function() {
        homeBarSearch.classList.add('on');
      });
  
      cb.addEventListener('click', function() {
        // 先判断是否有 on 类，若有则隐藏 protb 元素
        if (homeBarSearch.classList.contains('on')) {
          protb.style.display = 'none';
        }
        homeBarSearch.classList.remove('on');
      });
    });
  </script>




