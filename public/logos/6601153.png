<script>
    
// 股票信息
(function () {
    $.ajax({
        url: 'https://qt.gtimg.cn/q=sh688261',
        type: 'GET',
        success: function (res) {
            var elements = res.split("~");
            var endTime = elements[30];
            var endTime = endTime.substring(0, 4) + "-" + endTime.substring(4, 6) + "-" + endTime.substring(6, 8) + " " + endTime.substring(8, 10) + ":" + endTime.substring(10, 12) + ":" + endTime.substring(12, 14);
            var shou = elements[4]; //昨天的收盘价格
            var curr = elements[3]; //当前的价格
            var titlegp = elements[1]; //
            var shuzi = elements[2];//股票代码

            var code5 = elements[5];//涨跌%
            var code6 = elements[6];//成交量(手)
            var code7 = elements[7];//成交额(万)
            var code33 = elements[33];//最高
            var code34 = elements[34];//最低
            var code45 = elements[45];//市值

            var em = shou - curr;
            $(".he_fomli1 .he_fojtbp0").text(shuzi);
            $(".he_fomli1 .he_fojtbp1").text(titlegp);
            $(".inshcode .rh dt .b").text(curr);
            $(".inshcode .rh .tags  span").text(endTime); // 最后更新时间

            $(".inshcode .rh p .code6").text(code6);
            $(".inshcode .rh p .code7").text(code7);
            $(".inshcode .rh p .code33").text(code33);
            $(".inshcode .rh p .code34").text(code34);
            $(".inshcode .rh p .code45").text(code45);



            if (em > 0) {
                $(".inshcode .rh dt font").html("▼");
            } else {
                $(".inshcode .rh dt font").html("▲");
            };
            //console.log(elements)
            //console.log(elements[1] + '——' + elements[2]) 
        }
    });
})();

 

</script>











