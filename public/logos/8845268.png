<!-- 数字滚动 -->
<script type="text/javascript" src="./js/countup.min.js"></script>
<script>
  $(function () {
    // 获取手指在轮播图元素上的一个滑动方向（左右）

    // 获取界面上轮播图容器
    var $carousels = $('.carousel');
    var startX, endX;
    // 在滑动的一定范围内，才切换图片
    var offset = 50;
    // 注册滑动事件
    $carousels.on('touchstart', function (e) {
      // 手指触摸开始时记录一下手指所在的坐标x
      startX = e.originalEvent.touches[0].clientX;

    });
    $carousels.on('touchmove', function (e) {
      // 目的是：记录手指离开屏幕一瞬间的位置 ，用move事件重复赋值
      endX = e.originalEvent.touches[0].clientX;
    });
    $carousels.on('touchend', function (e) {
      //console.log(endX);
      //结束触摸一瞬间记录手指最后所在坐标x的位置 endX
      //比较endX与startX的大小，并获取每次运动的距离，当距离大于一定值时认为是有方向的变化
      var distance = Math.abs(startX - endX);
      if (distance > offset) {
        //说明有方向的变化
        //根据获得的方向 判断是上一张还是下一张出现
        $(this).carousel(startX > endX ? 'next' : 'prev');
      }
    })
    if (data) {
        var homepage = data
        var width = document.documentElement.clientWidth
        homepage.forEach((item, index) => {
          let dian = ''
          let img = ''
          console.log(width)
          if (width >= 768) {
            if (index == 0) {
              dian = `<li data-target="#carousel-example-generic" data-slide-to="0" class="active"></li>`
              img = `<div class="item active"><a href="${item.linkType}"><img src="${item.url}" alt="..."></a></div>`
            } else {
              dian = `<li data-target="#carousel-example-generic" data-slide-to="${index}"></li>`
              img = `<div class="item"><a href="${item.linkType}"><img src="${item.url}" alt="..."></a></div>`
            }
            console.log(img)
            $(".top_carousel").append(dian)
            $(".top_inner").append(img)
          } else {
            if (index == 0) {
              dian = `<li data-target="#carousel-example-generic" data-slide-to="0" class="active"></li>`
              img = `<div class="item active"><a href="${item.linkType}"><img src="${item.phoneUrl}" alt="..."></a></div>`
            } else {
              dian = `<li data-target="#carousel-example-generic" data-slide-to="${index}"></li>`
              img = `<div class="item"><a href="${item.linkType}"><img src="${item.phoneUrl}" alt="..."></a></div>`
            }
            $(".top_carousel").append(dian)
            $(".top_inner").append(img)
          }
        });
      }
      // if (planData) {
      //   let plan = planData
      //   plan.forEach((item, index) => {
      //     let dian = ''
      //     let img = ''
      //     console.log(item)
      //     if (index == 0) {
      //       dian = `<li data-target="#carousel-fangan-generic" data-slide-to="0" class="active"></li>`
      //       img = `<div class="item active"><a href="programme-detail.html?id=${item.id}"><img src="${item.imgUrl}" alt="..."></a></div>`
      //       $(".fangan_carousel").append(dian)
      //       $(".fangan_inner").append(img)
      //     } else {
      //       dian = `<li data-target="#carousel-fangan-generic" data-slide-to="${index}"></li>`
      //       img = `<div class="item"><a href="programme-detail.html?id=${item.id}"><img src="${item.imgUrl}" alt="..."></a></div>`
      //       $(".fangan_carousel").append(dian)
      //       $(".fangan_inner").append(img)
      //     }
      //   })
      // }
  });
</script>
<script type="text/javascript">
  $(function () {
    $("body").css("display","block")
    var windowsWidth = document.documentElement.clientWidth
    if (windowsWidth >= 1280) {
      //五大优势
      $(window).scroll(function () {
        if ($(".know_icon").hasClass("cur")) return false;
        if ($(".know_icon").hasClass("active")) {
          //数字跳动
          var options = {
            useEasing: true,
            useGrouping: true,
            separator: "",
            decimal: ".",
            prefix: "",
            suffix: ""
          };
          var num1 = new countUp("aUlist-num1", 2022, 1995, 0, 3, options);
          var num2 = new countUp("aUlist-num2", 0, 3, 0, 3, options);
          var num3 = new countUp("aUlist-num3", 0, 3, 0, 3, options);
          var num4 = new countUp("aUlist-num4", 0, 30, 0, 3, options);
          var num5 = new countUp("aUlist-num5", 1995, 2021, 0, 3, options);
          num1.start();
          num2.start();
          num3.start();
          num4.start();
          num5.start();
          if ($(".know_icon").addClass("cur"));
        }
      });


      /* 滚动效果 */
      var scrollArrty = ['.know_icon'];
      var scrI = 0;
      var scrHeight = window.screen.availHeight;
      $(window).scroll(function () {
        scrollFn();
      })

      function scrollFn() {
        if (scrI == scrollArrty.length) {
          return false;
        }
        var boxPos = $(scrollArrty[scrI]).offset().top;
        var winPos = $(window).scrollTop() + scrHeight - 300;
        if (boxPos < winPos) {
          $(scrollArrty[scrI]).addClass('active');
          scrI++;
          if (scrI < scrollArrty.length) {
            scrollFn();
          } else {
            return false;
          }
        } else {
          return false;
        }
      }
      scrollFn();
    } else {
      //五大优势
      $(window).scroll(function () {
        if ($(".know_icon_phone").hasClass("cur")) return false;
        if ($(".know_icon_phone").hasClass("active")) {
          //数字跳动
          var options = {
            useEasing: true,
            useGrouping: true,
            separator: "",
            decimal: ".",
            prefix: "",
            suffix: ""
          };
          var num1 = new countUp("phone-num1", 2022, 1995, 0, 3, options);
          var num2 = new countUp("phone-num2", 0, 3, 0, 3, options);
          var num3 = new countUp("phone-num3", 0, 5, 0, 3, options);
          var num4 = new countUp("phone-num4", 0, 30, 0, 3, options);
          var num5 = new countUp("phone-num5", 1995, 2021, 0, 3, options);
          num1.start();
          num2.start();
          num3.start();
          num4.start();
          num5.start();
          if ($(".know_icon_phone").addClass("cur"));
        }
      });


      /* 滚动效果 */
      var scrollArrty = ['.know_icon_phone'];
      var scrI = 0;
      var scrHeight = window.screen.availHeight;
      $(window).scroll(function () {
        scrollFn();
      })

      function scrollFn() {
        if (scrI == scrollArrty.length) {
          return false;
        }
        var boxPos = $(scrollArrty[scrI]).offset().top;
        var winPos = $(window).scrollTop() + scrHeight - 300;
        if (boxPos < winPos) {
          $(scrollArrty[scrI]).addClass('active');
          scrI++;
          if (scrI < scrollArrty.length) {
            scrollFn();
          } else {
            return false;
          }
        } else {
          return false;
        }
      }
      scrollFn();

    }
    if (windowsWidth  <=750) {
      $('.fangan_img').css("display","none")
      $('.fangan_phone_img').css("display","block")
    }
  })
</script>
