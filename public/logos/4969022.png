<!-- cookies -->
<div id="cookies-box" style="display:none;">
	<div class="container">
		<h4>Privacy and Cookies Policy</h4>
		<div class="d-lg-flex">
			<p>
			This website uses cookies to enhance your user experience and to collect statistics on network traffic. By continuing to use this site you agree to our use of cookies.
			Our <a href="privacy" target="_blank">Privacy and Cookie Policy</a> provides more information on the use and deactivation of cookies.
			</p>
			<div class="cookies-btn"><a href="javascript:alertCookie();">I understand</a></div>
		</div>
	</div>
</div>
        


<script type="text/javascript">

    window.onload = function() {
      var cookieValue =getCookie('foo_cookie');
      var foo_cookie = new Array();
    　var foo_cookie = cookieValue.split(";");
      //alert(foo_cookie[0]);
      //alert(cookieValue);
      if (foo_cookie[0]==""){
          //alert('沒有cookie');
          $('#cookies-box').css('display','block'); 
      }else{
          $('#cookies-box').css('display','none'); 
      }
    };

    function alertCookie() {
      // 設定 cookie 叫 foo_cookie
      // 在瀏覽器關閉後會自動被刪除
      document.cookie = 'foo_cookie=Hello';
      //alert(document.cookie);
      var cookieValue =getCookie('foo_cookie');
      var foo_cookie = new Array();
    　var foo_cookie = cookieValue.split(";");
      //alert(foo_cookie[0]);
      if (foo_cookie[0]==""){
          //alert('沒有cookie');
          $('#cookies-box').css('display','block'); 
      }else{
          $('#cookies-box').css('display','none'); 
      }
    }
    function getCookie(c_name){
        if (document.cookie.length>0)
          {
          c_start=document.cookie.indexOf(c_name + "=");
          if (c_start!=-1)
            { 
            c_start=c_start + c_name.length+1 ;
            c_end=document.cookie.indexOf("&",c_start);
            if (c_end==-1) c_end=document.cookie.length
            return unescape(document.cookie.substring(c_start,c_end));
            } 
          }
        return ""
    }
</script>

