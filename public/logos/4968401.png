			breakpoints: { 
				2560: { slidesPerView: 3, spaceBetween: 20 },  // 2560 사이즈 이하에서 2개 노출
				1680: { slidesPerView: 3, spaceBetween: 20 },  // 1680 사이즈 이하에서 2개 노출
