		#com_menu.header .gnb-mo > dl > dd .dd-scroll::-webkit-scrollbar{width:0;height:0;}
		#com_menu.header .gnb-mo > dl > dd::after{content:"";position:absolute;top:10px;right:10px;bottom:10px;width:3px;border-radius:999px;background:rgba(0,0,0,.10);pointer-events:none;}
		#com_menu.header .gnb-mo > dl > dd .scroll-thumb{position:absolute;right:9px;top:10px;width:5px;height:40px;border-radius:999px;background:rgba(0,0,0,.35);box-shadow:0 0 0 2px rgba(255,255,255,.6);pointer-events:none;opacity:1;transform:translateY(0);}
