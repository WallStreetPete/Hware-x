<script type="text/javascript">
	$(document).ready(function(){
		$(".search_btn").click(function(){
			$(".top_search").slideToggle("slow");
		});
	});

	(function () {
		function setup(wrap) {
			if (!wrap) return;
			const scroller = wrap.querySelector(".dd-scroll");
			if (!scroller) return;
			if (wrap.querySelector(".scroll-thumb")) return;

			const thumb = document.createElement("span");
			thumb.className = "scroll-thumb";
			wrap.appendChild(thumb);

			const update = () => {
			const ch = scroller.clientHeight;
			const sh = scroller.scrollHeight;
			const st = scroller.scrollTop;

			if (sh <= ch + 1) {
				thumb.style.opacity = "0";
				return;
			}
			thumb.style.opacity = "1";

			const track = wrap.clientHeight - 20;
			const ratio = ch / sh;
			const h = Math.max(28, Math.round(track * ratio));
			const maxTop = track - h;
			const top = Math.round((st / (sh - ch)) * maxTop);

			thumb.style.height = h + "px";
			thumb.style.transform = `translateY(${top}px)`;
			};

			update();
			scroller.addEventListener("scroll", update, { passive: true });
			window.addEventListener("resize", update);
		}

		function init() {
			document
			.querySelectorAll("#com_menu.header .gnb-mo > dl > dd")
			.forEach(setup);
		}

		document.addEventListener("DOMContentLoaded", init);

		const mo = document.querySelector("#com_menu.header .gnb-mo");
		if (mo) {
			new MutationObserver(init).observe(mo, {
			attributes: true,
			childList: true,
			subtree: true,
			});
		}
	})();


</script>
