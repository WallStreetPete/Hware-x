	<script>
		var baseUrl = $('.base-url').val();

			$('.go_search').on('click', 'a', function() {
				var data_url = $(this).data('url');
				var key = $(this).parents('.go_search').find('input').val();

				if (key == '') {
					alert("請輸入關鍵字！");
				} else {
					var url = baseUrl + '/search/' + data_url + '?keyword=' + encodeURIComponent(key);
					window.location.href = url;
				}
			});
	</script>

