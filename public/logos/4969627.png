<div id="loadingMask" style="display: none;">
  <img id="loading-image" src="https://www.adda.com.tw/asset/searchloading/loading-spinner-grey.gif" alt="Loading..." />
</div>

<script src="https://www.adda.com.tw/template/js/common.js"></script>
