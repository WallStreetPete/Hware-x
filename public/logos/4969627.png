	<script type="text/javascript">
if($('.gdpr02').length){
	setTimeout(function(){
		$('.gdpr02').addClass('show');
	},1000);

	$('.gdpr02 .cookie_mng').click(function(){
		$('body').addClass('no_overflow');
		$('.gdpr02_mng').addClass('show');
	});

	$('.gdpr02_mng .close_area, .gdpr02_mng .close_btn, .gdpr02_mng .accept_all').click(function(){
		$('body').removeClass('no_overflow');
		$('.gdpr02_mng').removeClass('show');
	});

	$('.gdpr02 .accept_all, .gdpr02_mng .accept_all').click(function(event) {
		$.get('https://www.adda.com.tw/gdpr/',function(){
			$('.gdpr02, .gdpr02_mng').removeClass('show');
			
			setTimeout(function(){
				$('.gdpr02, .gdpr02_mng').remove();
			},1000);
		});
	});

	$('.gdpr_ctl').click(function(event) {
		$.get('https://www.adda.com.tw/gdpr/ctl/',function(){
			$('.gdpr02, .gdpr02_mng').removeClass('show');
			
			setTimeout(function(){
				$('.gdpr02, .gdpr02_mng').remove();
			},1000);
		});
	});
}
</script>
