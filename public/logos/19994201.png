				<div class="elementor-element elementor-element-1600cc2 elementor-widget elementor-widget-html" data-id="1600cc2" data-element_type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<script>
(function () {
  const scriptEl = document.currentScript;

  const findHeadingAbove = () => {
    const htmlWidget = scriptEl.closest('.elementor-widget-html') || scriptEl.parentElement;
    let node = htmlWidget && htmlWidget.previousElementSibling;
    while (node) {
      const h = node.querySelector && node.querySelector('.elementor-heading-title, h1, h2, h3, h4, h5, h6');
      if (h) return h;
      node = node.previousElementSibling;
    }
    return document.querySelector('.elementor-heading-title:last-of-type, h2:last-of-type, h3:last-of-type');
  };

  const heading = findHeadingAbove();
  if (!heading) return;

  const original = heading.textContent.trim();
  heading.setAttribute('aria-label', original);
  heading.innerHTML = '';

  const frag = document.createDocumentFragment();
  for (const ch of original) {
    const span = document.createElement('span');
    span.textContent = ch;
    span.style.opacity = "0";
    span.style.color = "#6f7a83"; /* אפור רך יותר = מעבר חלק יותר */
    span.style.transition = "opacity 480ms cubic-bezier(.25,.75,.2,1), color 520ms cubic-bezier(.25,.75,.2,1)";
    frag.appendChild(span);
  }
  heading.appendChild(frag);

  const animate = () => {
    const chars = heading.querySelectorAll('span');
    chars.forEach((s, i) => {
      setTimeout(() => {
        // שלב 1: מופיע ברכות
        s.style.opacity = "1";

        // שלב 2: נהיה לבן בעדינות
        setTimeout(() => {
          s.style.color = "#FFFFFF";
        }, 150);

        // שלב 3: נמס לתכלת במקום לקפוץ
        setTimeout(() => {
          s.style.color = "#03D3DD"; // התכלת שלך
        }, 450);

      }, i * 28); // סטאגר עגול וחלק יותר
    });
  };

  const observer = new IntersectionObserver((entries, obs) => {
    if (entries.some(e => e.isIntersecting)) {
      animate();
      obs.disconnect();
    }
  }, { threshold: 0.25 });

  observer.observe(heading);
})();
</script>
				</div>
				</div>
