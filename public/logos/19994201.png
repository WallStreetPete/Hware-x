document.addEventListener("DOMContentLoaded", function () {
  // נשמור כאן את הוידאו הבא שצריך להיטען
  window._nextVideoUrl = null;

  // קליקים על העיגולים
  const circles = document.querySelectorAll("[data-video]");
  circles.forEach(circle => {
    circle.addEventListener("click", function (e) {
      e.preventDefault();

      let url = this.getAttribute("data-video") || "";
      if (url.includes("watch?v=")) {
        url = url.replace("watch?v=", "embed/");
      }
      window._nextVideoUrl = url;

      // פותח את הפופאפ
      elementorProFrontend.modules.popup.showPopup({ id: 346 });
    });
  });
});

// כשהפופאפ נפתח בפועל – מזריקים את ה-src
jQuery(document).on("elementor/popup/show", function (event, id, instance) {
  if (String(id) !== "346") return;

  // ננסה לאתר את ה-iframe בתוך הפופאפ שנפתח
  let $iframe = jQuery("#popup-video");
  if (!$iframe.length) {
    // fallback: נחפש בתוך הפופאפ האחרון שנפתח
    $iframe = jQuery(".dialog-widget").last().find("#popup-video");
  }

  if ($iframe.length && window._nextVideoUrl) {
    $iframe.attr("src", window._nextVideoUrl);
  }
});

// כשהפופאפ נסגר – מנקים את ה-src כדי לעצור את הנגן
jQuery(document).on("elementor/popup/hide", function (event, id) {
  if (String(id) !== "346") return;

  let $iframe = jQuery("#popup-video");
  if (!$iframe.length) {
    $iframe = jQuery(".dialog-widget").last().find("#popup-video");
  }
  if ($iframe.length) {
    $iframe.attr("src", "");
  }
});
</script>


</body>
</html>

