<!-- === GLOBAL PRELOADER: Smooth Black Fade (fast) + Video on Home === -->
<style>
#page-preloader {
  position: fixed;
  inset: 0;
  background: #000;
  z-index: 999999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  visibility: visible;
  transition: opacity 0.4s cubic-bezier(0.45, 0, 0.55, 1), visibility 0.4s ease;
}

/* נעלם */
#page-preloader.fade-out {
  opacity: 0;
  visibility: hidden;
}

/* וידאו בעמוד הבית בלבד */
#page-preloader video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* בעמודים אחרים – לא מציגים וידאו בכלל */
body:not(.home) #page-preloader video {
  display: none;
}
</style>

<div id="page-preloader">
  <video id="preload-video" autoplay muted playsinline preload="auto">
    <source src="https://nextvision-sys.com/wp-content/uploads/2025/08/Logo-Animation.mp4" type="video/mp4">
  </video>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const pre = document.getElementById('page-preloader');
  const vid = document.getElementById('preload-video');
  if (!pre) return;

  // בעמוד הבית – וידאו 1.5 שניות
  if (document.body.classList.contains('home')) {
    setTimeout(() => {
      pre.classList.add('fade-out');
      pre.addEventListener('transitionend', () => pre.remove(), { once: true });
    }, 1500);
  } 
  // בשאר הדפים – fade שחור רך ומהיר
  else {
    setTimeout(() => {
      pre.classList.add('fade-out');
      pre.addEventListener('transitionend', () => pre.remove(), { once: true });
    }, 300); // השהייה קצרה – 0.3 שניות לפני ההעלמות
  }
});
</script>

