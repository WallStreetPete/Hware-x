    <script src="/themes/pc/default/scripts/index.js?1777225400"></script>
    <script type="text/javascript">
        $(function () {
            // 原生 JavaScript 实现，不依赖 jquery.address 库
            // 为导航链接添加点击事件
            $('.js-get-content2 a').on('click', function(e) {
                e.preventDefault();

                var url = $(this).attr('href');
                var dataUrl = $(this).attr('data-url') || url;
                // 更新 URL（不刷新页面）- 只对有效的 URL 进行 pushState
                if (window.history && window.history.pushState && url && url !== 'javascript:;' && !url.startsWith('javascript:')) {
                    window.history.pushState({}, '', url);
                }

                // 更新 active 状态
                $('.js-get-content2 a').removeClass('active');
                $(this).addClass('active');

                // 加载新内容
                refreshProductList(dataUrl);
            });

            function refreshProductList( href ){
                var content2 = $('#content2');
                $.ajax({
                    type:"get",
                    url: href,
                    success: function(data){
                        var new_content1 = $(data).find("#content2");
                        content2.html(new_content1.html());
                    }
                });
            }
        });
    </script>
    <script>
        $(document).ready(function(){
            _app.index();

            function hideDotsLi(){
                if($('.wks_recommend .slick-dots li').length==1){
                    $('.wks_recommend .slick-dots').hide();
                }
            }
            hideDotsLi();
        });
    </script>
