<script src="/template/default/js/wow.min.js"></script>
<script>
    var wow = new WOW({
        boxClass: 'wow',
        animateClass: 'animated',
        offset: 0,
        mobile: false,
        live: true
    });
    wow.init();

    // $('.openWechat').click(function () {
    //     $(this).children('.wechatCode').toggle();
    // })
    // $('.openVideo').click(function () {
    //     $(this).children('.wechatCode').toggle();
    // })
    $('.openWechat').hover(
      function () {
         $(this).children('.wechatCode').toggle();
      },
      function () {
         $(this).children('.wechatCode').toggle();
      }
    );
    
    $('.openVideo').hover(
      function () {
         $(this).children('.wechatCode').toggle();
      },
      function () {
         $(this).children('.wechatCode').toggle();
      }
    );
    // function openWechat() {
    //     $('.wechatCode').
    // }
    
    $(window).scroll(function() {
        // console.log($(document).scrollTop())
        // console.log($('.footer2').offset().top)
        // 总高度
        let scrollHeight = document.documentElement.scrollHeight || document.body.scrollHeight
        // 可视区高度
        let windowHeight = document.documentElement.clientHeight || document.body.clientHeight
        // 变量scrollTop为当前页面的滚动条纵坐标位置
        let scrollTop = document.documentElement.scrollTop || document.body.scrollTop
        // 获取距离底部的高度
        var scrollBottom = scrollHeight - windowHeight - scrollTop
        if (scrollBottom < ($('.footer2').height() + $('.footer3').height())) {
          $('.footer1').css({'position':'static'})
        }else{
            $('.footer1').css('position','fixed')
        }

    });
    
    $('.addt1').click(function () { 
        $(this).siblings().stop().slideToggle()
        $(this).children('.addClose').toggle()
        $(this).children('.addOpen').toggle()
        $(this).parent().siblings().children('.addt2').stop().slideUp().siblings().children('.addClose').hide().siblings('.addOpen').show()
    })

    
</script>

</body>
